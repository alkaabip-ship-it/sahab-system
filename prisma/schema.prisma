generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        String   @default("VIEWER")
  permissions String?
  createdAt   DateTime @default(now())
}

model Project {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  clientName    String
  value         Float
  executionDate DateTime?
  status        String    @default("QUOTE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bills       Bill[]
  invoices    Invoice[]
  issues      ProjectIssue[]
  evaluations SupplierEvaluation[]
}

model Supplier {
  id             String   @id @default(cuid())
  zohoId         String?  @unique
  name           String
  phone          String?
  email          String?
  serviceType    String
  recommendation String   @default("UNDER_REVIEW")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bills       Bill[]
  issues      ProjectIssue[]
  evaluations SupplierEvaluation[]
}

model Bill {
  id             String    @id @default(cuid())
  zohoId         String?   @unique
  billNumber     String
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id])
  amount         Float
  billDate       DateTime
  dueDate        DateTime?
  status         String    @default("UNPAID")
  attachmentUrl  String?
  projectCode    String?
  zohoCustomerName String? // Customer Name from Zoho Bills — used to link to project by clientName
  isLinked       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ProjectIssue {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id])
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  issueType  String
  impact     String
  notes      String?
  status     String    @default("OPEN")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model SupplierEvaluation {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  supplierId     String
  supplier       Supplier @relation(fields: [supplierId], references: [id])
  performance    String
  repeatBusiness Boolean
  notes          String?
  createdAt      DateTime @default(now())
}

model Invoice {
  id            String    @id @default(cuid())
  zohoId        String?   @unique
  invoiceNumber String    @unique
  customerName  String
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  amount        Float
  balance       Float     @default(0)
  invoiceDate   DateTime
  dueDate       DateTime?
  status        String    @default("UNPAID") // PAID, UNPAID, PARTIAL, VOID
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ZohoSyncLog {
  id          String   @id @default(cuid())
  syncType    String
  status      String
  message     String?
  itemsSynced Int      @default(0)
  createdAt   DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Employee {
  id              String    @id @default(cuid())
  name            String
  salary          Float
  residencyExpiry DateTime?
  createdAt       DateTime  @default(now())
}

model CompanyExpense {
  id         String    @id @default(cuid())
  key        String    @unique
  label      String
  amount     Float     @default(0)
  period     String    // MONTHLY, ANNUAL, BIANNUAL
  expiryDate DateTime?
}
