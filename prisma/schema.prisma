generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Bill {
  id               String    @id
  zohoId           String?   @unique
  billNumber       String
  supplierId       String?
  projectId        String?
  amount           Float
  billDate         DateTime
  dueDate          DateTime?
  status           String    @default("UNPAID")
  attachmentUrl    String?
  projectCode      String?
  zohoCustomerName String?
  isLinked         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  project          Project?  @relation(fields: [projectId], references: [id])
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
}

model CompanyExpense {
  id         String    @id
  key        String    @unique
  label      String
  amount     Float     @default(0)
  period     String
  expiryDate DateTime?
}

model Customer {
  id        String   @id
  zohoId    String?  @unique
  name      String
  phone     String?
  email     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Employee {
  id              String    @id
  name            String
  salary          Float
  residencyExpiry DateTime?
  createdAt       DateTime  @default(now())
}

model InventoryItem {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String
  category    String   @default("OTHER")
  quantity    Float    @default(0)
  minQuantity Float    @default(0)
  unit        String   @default("قطعة")
  location    String?
  condition   String   @default("GOOD")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}

model Invoice {
  id            String    @id
  zohoId        String?   @unique
  invoiceNumber String    @unique
  customerName  String
  projectId     String?
  amount        Float
  balance       Float     @default(0)
  invoiceDate   DateTime
  dueDate       DateTime?
  status        String    @default("UNPAID")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  project       Project?  @relation(fields: [projectId], references: [id])
}

model LoginLog {
  id        String   @id
  userId    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

model Project {
  id                 String               @id
  code               String               @unique
  name               String
  clientName         String
  value              Float
  executionDate      DateTime?
  status             String               @default("QUOTE")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  bills              Bill[]
  invoices           Invoice[]
  issues             ProjectIssue[]
  supplierEvals      SupplierEvaluation[]
  tasks              Task[]
}

model ProjectIssue {
  id         String    @id
  projectId  String
  supplierId String?
  issueType  String
  impact     String
  notes      String?
  status     String    @default("OPEN")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  project    Project   @relation(fields: [projectId], references: [id])
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
}

model ProjectPlan {
  id        String   @id
  name      String
  saleValue Float    @default(0)
  items     String
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Setting {
  id    String @id
  key   String @unique
  value String
}

model Supplier {
  id                 String               @id
  zohoId             String?              @unique
  name               String
  phone              String?
  email              String?
  serviceType        String
  recommendation     String               @default("UNDER_REVIEW")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  bills              Bill[]
  issues             ProjectIssue[]
  supplierEvals      SupplierEvaluation[]
}

model SupplierEvaluation {
  id             String   @id
  projectId      String
  supplierId     String
  performance    String
  repeatBusiness Boolean
  notes          String?
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id])
  supplier       Supplier @relation(fields: [supplierId], references: [id])
}

model Task {
  id                           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  title                        String
  description                  String?
  status                       String    @default("PENDING")
  priority                     String    @default("MEDIUM")
  assignee                     String?
  projectId                    String?
  dueDate                      DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @default(now())
  notes                        String?
  assignedToId                 String?
  createdById                  String?
  taskDate                     String?
  assignedTo                   User?     @relation("Task_assignedToIdToUser", fields: [assignedToId], references: [id], onUpdate: NoAction)
  createdBy                    User?     @relation("Task_createdByIdToUser", fields: [createdById], references: [id], onUpdate: NoAction)
  project                      Project?  @relation(fields: [projectId], references: [id])

  @@index([assignedToId])
  @@index([createdById])
  @@index([taskDate])
}

model User {
  id                           String     @id
  name                         String
  email                        String     @unique
  password                     String
  role                         String     @default("VIEWER")
  permissions                  String?
  createdAt                    DateTime   @default(now())
  loginLogs                    LoginLog[]
  assignedTasks                Task[]     @relation("Task_assignedToIdToUser")
  createdTasks                 Task[]     @relation("Task_createdByIdToUser")
}

model ZohoSyncLog {
  id          String   @id
  syncType    String
  status      String
  message     String?
  itemsSynced Int      @default(0)
  createdAt   DateTime @default(now())
}

model agent_alerts {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  type            String
  severity        String    @default("INFO")
  title           String
  message         String?
  project_id      String?
  employee_id     String?
  is_read         Boolean?  @default(false)
  acknowledged_at DateTime? @db.Timestamptz(6)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
}

model agent_config {
  id               String    @id @default("1")
  is_active        Boolean?  @default(true)
  interval_minutes Int?      @default(15)
  last_run         DateTime? @db.Timestamptz(6)
}

model agent_daily_summaries {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  summary_date String
  content      Json?     @default("{}")
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model agent_messages {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  role       String
  content    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model agent_runs {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  started_at   DateTime? @default(now()) @db.Timestamptz(6)
  completed_at DateTime? @db.Timestamptz(6)
  perception   String?
  reasoning    String?
  actions      Json?     @default("[]")
  outcome      String?
}

model event_management_events {
  id         String   @id
  data       Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model project_margins {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  project_id     String
  project_name   String?
  margin_percent Float?
  revenue        Float?
  cost           Float?
  recorded_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@index([project_id])
  @@index([recorded_at])
}
